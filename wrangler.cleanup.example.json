{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cleanup-worker",
  "main": "workers/cleanup.ts",
  "compatibility_date": "2024-03-20",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["* * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "drizzle",
      "database_name": "moemail",
      "database_id": "${DATABASE_ID}"
    }
  ]
}
